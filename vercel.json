{
  "version": 2,
  "builds": [
    {
      "src": "test-webapp/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/test-webapp/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/test-webapp/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "/test-webapp/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/test-webapp/index.html"
    }
  ]
}
